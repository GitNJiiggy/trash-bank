{
  "buildCommand": "cd backend && npm install",
  "outputDirectory": "docs",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/docs/$1"
    }
  ],
  "functions": {
    "backend/server.js": {
      "runtime": "nodejs22.x"
    }
  }
}